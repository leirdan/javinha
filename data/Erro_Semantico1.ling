class Main {
    public static void main(String[] a) {
        System.out.println(new Foo().teste());
    }
}
class Foo {
    public int teste() {
        int x;
        x = 1;
        if (x)
            x = 2;
        else
            x = 3;
        while (42)
            x = x + 1;
        return x;
    }
}

/**
* Aqui começa o programa
**/
class Programa{
    public static void main(String[] a){
	    System.out.println(new Funcao().funcao1(10));
    }
}

/**
* Aqui tem uma funcao
**/
class Funcao {

    public int funcao1(int num){
        // Uma variável aqui
	    int n_aux ;
	    if (1 > num)
	        n_aux = 1 ;
	    else
            // Aqui tem algo
	        n_aux = num * (this.funcao1(num-1)) ;
	    return n_aux ;
    }

}